{
  "expo": {
    "name": "income-tracker-app",
    "slug": "income-tracker-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "incometrackerapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ercuumeent.incometrackerapp",
      "infoPlist": {
        "NSCalendarsUsageDescription": "Bu uygulama, gelir ve gider işlemlerinizi cihaz takviminizle senkronize etmek için takvim erişimi ister.",
        "NSRemindersUsageDescription": "Bu uygulama, hatırlatıcı oluşturabilmek için erişim ister.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.ercuumeent.incometrackerapp",
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "Bu uygulama, gelir ve gider işlemlerinizi cihaz takviminizle senkronize etmek için takvim erişimi ister."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7117be9b-ba71-4c5d-9e93-36c8a8ae2292"
      }
    }
  }
}